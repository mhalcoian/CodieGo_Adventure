@{
    ViewData["Title"] = "Leaderboard";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    var podiumOrder = new int[] { 1, 0, 2 };
}

<style>
    .lb-header {
        text-align: center;
        margin-bottom: 35px;
    }

        .lb-header h1 {
            color: #00eaff;
            font-size: 28px;
            letter-spacing: 2px;
        }

        .lb-header p {
            font-size: 12px;
            opacity: .7;
        }

    .lb-stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 18px;
        margin: 25px 0 40px;
    }

    .lb-stat {
        border: 1px solid rgba(0,255,255,.35);
        padding: 14px;
        text-align: center;
        border-radius: 12px;
        background: rgba(0,0,0,.35);
        font-size: 12px;
    }

        .lb-stat strong {
            display: block;
            color: #00eaff;
            font-size: 18px;
            margin-top: 6px;
        }

    .filters {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .filter-left span {
        margin-right: 8px;
        padding: 6px 12px;
        border: 1px solid rgba(255,255,255,.25);
        font-size: 11px;
        cursor: pointer;
        opacity: .7;
    }

        .filter-left span.active {
            border-color: #00eaff;
            color: #00eaff;
            opacity: 1;
        }

    .filter-right input {
        background: rgba(0,0,0,.6);
        border: 1px solid rgba(255,255,255,.25);
        padding: 6px 10px;
        color: #fff;
        border-radius: 8px;
        font-size: 11px;
    }

    /* PODIUM */
    .podium {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
        margin-bottom: 40px;
        align-items: end; /* important */
    }

    .first-place {
        transform: translateY(-20px);
    }

    .podium-card {
        padding: 22px;
        border-radius: 16px;
        background: linear-gradient(135deg,#050a18,#0b1734);
        border: 2px solid;
        text-align: center;
        position: relative;
    }

        .podium-card img {
            height: 120px;
            width: 180px;
            border-radius: 10%;
        }

        .podium-card h3 {
            margin-top: 15px;
            color: #5df6ff;
        }

        .podium-card.gold {
            border-color: #ffd54a;
            box-shadow: 0 0 40px rgba(255,213,74,.4);
        }

        .podium-card.silver {
            border-color: #cfd8dc;
            box-shadow: 0 0 40px rgba(207,216,220,.4);
        }

        .podium-card.bronze {
            border-color: #ff8f3c;
            box-shadow: 0 0 40px rgba(255,143,60,.4);
        }

    .crown {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 26px;
    }

    /* TABLE */
    .rankings {
        border: 1px solid rgba(0,255,255,.35);
        border-radius: 14px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    th, td {
        padding: 12px;
        text-align: center;
    }

    th {
        background: rgba(0,255,255,.1);
        color: #5df6ff;
    }

    tr {
        border-bottom: 1px solid rgba(255,255,255,.08);
    }

        tr.highlight {
            background: rgba(0,234,255,.12);
        }

    .rank {
        color: #ffd54a;
        font-weight: bold;
    }

    .xp {
        color: #00eaff;
    }
</style>

<div class="lb-header">
    <h1>LEADERBOARD</h1>
    <p>Top 10 coders</p>
</div>

<!-- PODIUM -->
<div class="podium">
    @foreach (var pos in podiumOrder)
    {
        var entry = pos < Model.Count ? Model[pos] : null;

        string medalClass =
        pos == 0 ? "gold" :
        pos == 1 ? "silver" :
        "bronze";

        string label =
        pos == 0 ? "🥇 First Placer" :
        pos == 1 ? "🥈 Second Placer" :
        "🥉 Third Placer";

        <a asp-controller="@(entry != null ? "Users" : "Home")" asp-action="@(entry != null ? "Profile" : "Leaderboard")" asp-route-id="@entry?.ChallengesProgress.Profiles.ProfileId" class="text-decoration-none text-light">
            <div class="podium-card @medalClass @(pos == 0 ? "first-place" : "")">
                @if (pos == 0)
                {
                    <div class="crown">👑</div>
                }

                <img src="@entry?.ChallengesProgress.Profiles?.Base64StringImage"
                     alt="@entry?.ChallengesProgress.Profiles?.ImageName" />

                <h3>@(entry?.ChallengesProgress.Profiles?.DisplayName ?? "—")</h3>
                <p>@(entry?.ChallengesProgress.AccumulatedPoints.ToString("n0") ?? "0") Points</p>
                <small>@label</small>
            </div>
        </a>
    }
</div>

<!-- RANKINGS TABLE -->
<div class="rankings">
    <table>
        <thead>
            <tr>
                <th>RANK</th>
                <th>PLAYER</th>
                <th>POINTS</th>
                <th>BEST TIME</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var entry = Model[i];
                <tr class="@(entry.ChallengesProgress.ProfileId == ViewBag.CurrentId ? "highlight" : "")"
                    onclick="window.location.href='/Users/Profile/@entry.ChallengesProgress.Profiles.ProfileId'">
                    <td class="rank">@(i + 1)</td>
                    <td>@(entry.ChallengesProgress.Profiles?.DisplayName ?? "Unknown")</td>
                    <td class="xp">@entry.ChallengesProgress.AccumulatedPoints.ToString("n0")</td>
                    <td>@(entry.ChallengesProgress.Time > 0 ? TimeSpan.FromSeconds(entry.ChallengesProgress.Time).ToString(@"mm\:ss") : "-")</td>
                </tr>
            }
            <tr class="highlight">
                <td class="rank">@ViewBag.RankLevel</td>
                <td>@ViewBag.PlayerName</td>
                <td class="xp">@ViewBag.AccumulatedPoints</td>
                <td>@ViewBag.BestTime</td>
            </tr>
        </tbody>
    </table>
</div>
