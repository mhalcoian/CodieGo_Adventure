@model Profiles
@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<style>
    /* ===== MAIN PROFILE CONTAINER FEEL ===== */
    .card-section {
        background: linear-gradient(145deg,#0a1533,#0f1e4d);
        border: 1px solid rgba(93,246,255,.25);
        border-radius: 20px;
        padding: 22px;
        margin-bottom: 28px;
        box-shadow: 0 0 35px rgba(0,234,255,.08);
    }

    /* ===== HEADER ===== */
    .profile-header {
        position: relative;
        height: 180px;
        border-radius: 18px;
        background: linear-gradient(135deg,#0b1734,#0f1e4d);
        border: 1px solid rgba(93,246,255,.4);
        box-shadow: inset 0 0 40px rgba(0,234,255,.12);
        margin-bottom: 20px;
        overflow: hidden;
        display:flex;
        align-items: center;
        justify-content:space-between;
        gap:1rem;
    }

        /* avatar */
        .profile-header img {
            width: 160px;
            height: 140px;
            border-radius: 10%;
            border: 3px solid #7bff9c;
            box-shadow: 0 0 20px rgba(123,255,156,.5);
        }

        /* name */
        .profile-header h3 {
            font-family: 'Orbitron', sans-serif;
            color: #7bff9c;
            margin: 0;
        }

    /* ===== BIO + STATS ROW ===== */
    .bio-card {
        background: rgba(0,0,0,.25);
        border-radius: 14px;
        padding: 18px;
        line-height: 1.6;
    }

    .progress-card {
        text-align: center;
        background: rgba(0,0,0,.25);
        border-radius: 14px;
        padding: 18px;
    }

        .progress-card strong {
            font-size: 26px;
            color: #7bff9c;
        }

    /* ===== SECTION TITLES ===== */
    .section-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        letter-spacing: 1px;
        color: #5df6ff;
        margin-bottom: 16px;
    }

    /* ===== HORIZONTAL GAME HISTORY ===== */

    .history-row {
        display: flex;
        gap: 14px;
        overflow-x: auto;
        padding-bottom: 6px;
        scrollbar-width: thin;
        height: 200px;
        scrollbar-width:none;
    }

    /* ===== TILE ===== */

    .history-tile {
        min-width: 200px;
        flex-shrink: 0;
        background: linear-gradient(135deg,#0c183a,#0f1e4d);
        border: 1px solid rgba(93,246,255,.25);
        border-radius: 14px;
        padding: 14px 12px;
        text-align: center;
        box-shadow: 0 0 18px rgba(0,234,255,.08);
        transition: transform .15s ease, box-shadow .15s ease;
    }

    /* icon */
    .tile-icon {
        font-size: 26px;
        margin-bottom: 6px;
    }

    /* title */
    .tile-title {
        font-weight: bold;
        font-size: 14px;
        margin-bottom: 4px;
    }

    /* status */
    .tile-status {
        font-size: 12px;
        color: #ffdd00;
        margin-bottom: 8px;
    }

    /* score */
    .tile-score {
        font-size: 14px;
        color: #5df6ff;
        margin-bottom: 8px;
    }

    /* meta text */
    .tile-meta {
        opacity: .7;
        font-size: 11px;
    }


    /* PUZZLE + BADGES */
    .puzzle-badges-section {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    /* grid spacing improvement */
    .card-grid {
        position: relative;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 22px;
    }

    /* BADGE PANEL */
    .badge-card {
        position: relative;
        padding: 22px 18px;
        border-radius: 18px;
        background: linear-gradient(145deg, #0b1734, #0f1e4d);
        border: 1px solid rgba(93,246,255,.35);
        box-shadow: 0 0 20px rgba(0,234,255,.12), inset 0 0 20px rgba(0,234,255,.05);
        text-align: center;
        transition: all .28s ease;
        cursor: pointer;
    }

    .tooltip-text {
        visibility: hidden;
        opacity: 0;
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: #ccc;
        color: #111;
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 12px;
        transition: 0.2s ease;
        z-index: 100;
        width: 100%;
    }

    .badge-card:hover .tooltip-text {
        visibility: visible;
        opacity: 1;
    }

    /* icon */
    .badge-card span {
        font-size: 30px;
        display: block;
        margin-bottom: 10px;
    }

    /* title */
    .badge-card small {
        font-size: 13px;
        letter-spacing: .5px;
        opacity: .9;
    }
</style>

<!-- PROFILE HEADER -->
<div class="profile-header">
    <div class="d-flex align-items-center" style="width:50%;margin-left:1rem;">
        <img src="@Model.Base64StringImage"
             alt="@Model.ImageName"
             style="@(ViewBag.IsCurrentId == Model.ProfileId ? "cursor:pointer;" : "")"
             onclick="@(ViewBag.IsCurrentId == Model.ProfileId ? "openEditModal();" : "")" />
        <div class="ms-3">
            <h3>@Model.DisplayName</h3>
            <div>@Model.Bio</div>
        </div>
    </div>

    <div style="width:100%;display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-right:2rem;">


        <div class="progress-card">
            <strong>@ViewBag.TotalModulesCompleted/9</strong><br />
            <span>Modules</span><br /><small class="text-muted">Completed</small>
        </div>

        <div class="progress-card">
            <strong>@ViewBag.TotalChallengePoints.ToString("n0")</strong><br />
            <span>Challenge</span><br /><small class="text-muted">Accumulated Points</small>
        </div>

        <div class="progress-card">
            <strong>@ViewBag.BestTimeFormatted</strong><br />
            <span>Challenge</span><br /><small class="text-muted">Best Time</small>
        </div>

        <div class="progress-card">
            <strong>@ViewBag.RankLevel</strong><br />
            <span>Challenge</span><br /><small class="text-muted">Rank</small>
        </div>

    </div>

</div>

@if (ViewBag.CertUnlocked == true)
{
    <div class="card-section" style="width:auto;">
        <img src="~/images/certificate/bronze-completion.png" alt="Alternate Text" style="height:600px;width:100%;" />
    </div>
}

<!-- RECENT ACTIVITY -->
<div class="card-section">
    <h4 class="section-title">RECENT CHALLENGE</h4>

    <div class="history-row">

        @foreach (var history in Model.HistoryCollection)
        {
            <div class="history-tile">
                <div class="tile-icon">🧩</div>

                <div class="tile-title">@history.ChallengesProgress.Challenges.Title</div>

                <div class="tile-status">@history.ChallengesProgress.Status</div>

                <div class="tile-score">@history.DailyPoints.ToString("n0") Points</div>

                <small class="tile-meta">@history.logDate.ToString("MMM dd, yyyy")</small>
            </div>
        }

    </div>
</div>

<div class="puzzle-badges-section card-section">
    <h4 class="section-title">ACHIEVEMENTS & BADGES</h4>

    <div class="card-grid">

        @foreach (var achievement in Model.AchievementBadgeCollection.OrderByDescending(a => a.BadgeId))
        {
            <div class="badge-card">
                <span>⭐</span>
                <br />@achievement.BadgeName

                <div class="tooltip-text">
                    @achievement.Description
                </div>
            </div>
        }

        @foreach (var puzzle in Model.PuzzlesCollection.OrderByDescending(p => p.PuzzleId))
        {
            <div class="badge-card">
                <span>🧩</span>
                <br />@puzzle.PuzzleName

                <div class="tooltip-text">
                    @puzzle.Description
                </div>
            </div>
        }

        <div class="badge-card">
            <span>⭐</span>
            <br />Thank You!

            <div class="tooltip-text">
                Developer's thank you gift.
            </div>
        </div>

    </div>
</div>
