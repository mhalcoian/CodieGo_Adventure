@using CodieGo_Adventure.DTO
@model ResetPasswordToken
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@if (TempData["Popup"] != null)
{
    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const popup = @Html.Raw(TempData["Popup"]);
                showGameToast(
                    popup.type,
                    popup.title,
                    popup.message
                );
            });
        </script>
    }
}

<style>
    .auth-center {
        min-height: calc(100vh - 120px);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .auth-box {
        width: 420px;
        text-align: center;
    }

        .auth-box h1 {
            color: #48eaff;
            letter-spacing: 3px;
            font-size: 22px;
            margin-bottom: 30px;
        }

    /* INPUT */
    .auth-field {
        position: relative;
        margin-bottom: 18px;
    }

        .auth-field input {
            width: 100%;
            padding: 14px 40px 14px 14px;
            background: rgba(5,15,35,.9);
            border: 1px solid rgba(0,255,255,.5);
            color: #dffaff;
            outline: none;
        }

            .auth-field input::placeholder {
                color: rgba(223,250,255,.55);
            }

    .password-field {
        position: relative;
    }

        .password-field input {
            padding-right: 45px;
        }

    .eye {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6ef9ff;
        font-size: 18px;
        opacity: 0.8;
        transition: 0.2s;
    }

        .eye:hover {
            color: #00ffff;
            opacity: 1;
        }

    /* BUTTON */
    .auth-btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(90deg,#00eaff,#00bcd4);
        border: none;
        color: #031318;
        font-weight: 600;
        letter-spacing: 3px;
        cursor: pointer;
        box-shadow: 0 0 20px rgba(0,255,255,.45);
        transition: .25s;
    }

        .auth-btn:hover {
            transform: scale(1.03);
        }

    /* PASSWORD RULES */
    .rules {
        text-align: left;
        border: 1px solid rgba(0,255,255,.35);
        padding: 12px;
        font-size: 11px;
        margin-top: 10px;
        background: rgba(0,0,0,.35);
    }
</style>

<div class="auth-center">
    <div class="auth-box">
        <h1>NEW PASSWORD</h1>

        <form asp-action="ResetPassword" method="post"
              onsubmit="showGameLoader('Updating...', 'Securing account')">

            <input type="hidden" name="Token" value="@Model.Token" />

            <div class="auth-field password-field">
                <input type="password" maxlength="20" name="password" id="password" placeholder="Create a strong password" />
                <span class="eye" onclick="togglePassword()">👁</span>
            </div>

            <div class="rules">
                <div id="rule-length">At least 8 characters</div>
                <div id="rule-uppercase">1 Uppercase letter</div>
                <div id="rule-number-symbol">1 Number or symbol</div>
            </div>
            <div class="auth-field password-field">
                <input type="password" maxlength="20" name="confirm_password" id="confirm_password" placeholder="Re-enter your password" />
                <span class="eye" onclick="togglePassword()">👁</span>
            </div>

            <button class="auth-btn">SUBMIT</button>
        </form>
    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById("password");
        const input2 = document.getElementById("confirm_password");
        input.type = input.type === "password" ? "text" : "password";
        input2.type = input2.type === "password" ? "text" : "password";
    }

    document.addEventListener("DOMContentLoaded", () => {
        const passwordInput = document.querySelector('input[name="password"]');

        const ruleLength = document.getElementById("rule-length");
        const ruleUppercase = document.getElementById("rule-uppercase");
        const ruleNumberSymbol = document.getElementById("rule-number-symbol");

        // Set default color to red
        ruleLength.style.color = "red";
        ruleUppercase.style.color = "red";
        ruleNumberSymbol.style.color = "red";

        passwordInput.addEventListener("input", function() {
            const value = passwordInput.value;

            // At least 8 characters
            if (value.length >= 8) {
                ruleLength.style.color = "lightgreen";
            } else {
                ruleLength.style.color = "red";
            }

            // At least 1 uppercase letter
            if (/[A-Z]/.test(value)) {
                ruleUppercase.style.color = "lightgreen";
            } else {
                ruleUppercase.style.color = "red";
            }

            // At least 1 number or symbol
            if (/\d/.test(value) || /[^A-Za-z0-9]/.test(value)) {
                ruleNumberSymbol.style.color = "lightgreen";
            } else {
                ruleNumberSymbol.style.color = "red";
            }
        });
    });
</script>
