@model Users

@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@if (TempData["Popup"] != null)
{
    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const popup = @Html.Raw(TempData["Popup"]);
                showGameToast(
                    popup.type,
                    popup.title,
                    popup.message
                );
            });
        </script>
    }
}

<style>
    .topbar {
        height: 60px;
        padding: 0 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(0,255,255,.25);
    }

    .logo {
        color: #5df6ff;
        letter-spacing: 2px
    }

    .top-links a {
        color: #7ffcff;
        font-size: 12px;
        margin-left: 20px;
        text-decoration: none;
    }

    .wrapper {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        padding: 50px;
        gap: 40px;
    }

    /* LEFT */
    .left h1 {
        font-size: 38px;
        color: #64f7ff;
        margin-bottom: 20px;
    }

    .left p {
        max-width: 480px;
        line-height: 1.6;
        opacity: .85
    }

    .feature {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
       
        .feature {
            color: #64f7ff;
        }

        .community {
            color: #a855f7;
        }
        

    /* RIGHT */
    .panel {
        border: 1px solid rgba(0,255,255,.45);
        padding: 30px;
        background: rgba(3,10,25,.9);
        box-shadow: 0 0 25px rgba(0,255,255,.25);
    }

        .panel h2 {
            color: #6ef9ff;
            margin-bottom: 20px;
        }

    .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px
    }

    .field {
        margin-bottom: 14px
    }

        .field input {
            width: 100%;
            padding: 12px;
            background: transparent;
            border: 1px solid rgba(0,255,255,.4);
            color: #dffaff;
        }

    .password-field {
        position: relative;
    }

        .password-field input {
            padding-right: 45px;
        }

    .eye {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6ef9ff;
        font-size: 18px;
        opacity: 0.8;
        transition: 0.2s;
    }

        .eye:hover {
            color: #00ffff;
            opacity: 1;
        }

    .hint {
        font-size: 11px;
        margin-top: 6px;
        color: #7bff9c;
    }

    .check {
        border: 1px solid rgba(0,255,255,.35);
        padding: 12px;
        font-size: 11px;
        margin-top: 10px;
        background: rgba(0,0,0,.35);
    }

    .btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(90deg,#00eaff,#00bcd4);
        border: none;
        color: #031318;
        font-weight: 600;
        letter-spacing: 3px;
        cursor: pointer;
        box-shadow: 0 0 20px rgba(0,255,255,.45);
        transition: .25s;
    }

        .btn:hover {
            transform: scale(1.03);
        }
                
    footer {
        position: absolute;
        bottom: 15px;
        left: 50px;
        font-size: 11px;
        opacity: .6;
    }

    .panel form {
        display: flex;
        flex-direction: column;
    }

    #strengthBar {
        width: 100%;
        height: 6px;
        background: rgba(255,255,255,.1);
        margin-top: 6px;
        border-radius: 5px;
        overflow: hidden;
    }

    #strengthFill {
        height: 100%;
        width: 0%;
        transition: all .3s;
    }

    #strengthText {
        font-size: 11px;
    }
</style>

<div class="topbar">
    <div class="logo">&lt;/&gt; CODIE GO ADVENTURE</div>
    <div class="top-links">
        <small>Already have an account?</small>
        <a asp-controller="Account" asp-action="Login">
            LOGIN
        </a>
    </div>
</div>

<div class="wrapper">

    <!-- LEFT -->
    <div class="left">
        <h1>JOIN THE CODIE<br />ADVENTURE</h1>
        <p>
            Enter the world of C# programming education and 
            unlock your potential as a coder.
        </p>

        <div class="feature">
            <div>
                <h5>Learn to Code</h5>
                Master programming through interactive modules <br />
                and real-world challenges.
            </div>
            <div class="community">
                <h5>Earn Achievements</h5>
                Complete modules, and climb the leaderboard.
            </div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="panel">
        <h2>CREATE ACCOUNT</h2>

        <form asp-action="RegisterAccount" method="post"
              onsubmit="showGameLoader('Registering...', 'Validating player inputs')">

            <div class="field">
                <input name="username" id="username" min="4" maxlength="20" placeholder="Username" value="@ViewBag.Username" />
                <small id="usernameStatus"></small>
            </div>

            <div class="field">
                <input name="email" placeholder="Email address" value="@ViewBag.Email" />
            </div>

            <div class="field password-field">
                <input type="password" maxlength="20" name="password" id="password" placeholder="Create password" value="@ViewBag.Password" />
                <span class="eye" onclick="togglePassword()">👁</span>
            </div>

            <div id="passwordStrengthContainer" style="display:none;">
                <div id="strengthBar">
                    <div id="strengthFill"></div>
                </div>
                <small id="strengthText"></small>
            </div>
            <div id="passwordRules" class="check" style="display:none;">
                <div id="rule-length">At least 8 characters</div>
                <div id="rule-uppercase">1 Uppercase letter</div>
                <div id="rule-number-symbol">1 Number and Special character</div>
            </div>

            <div class="field password-field">
                <input type="password" maxlength="20" name="confirm_password" id="confirm_password" placeholder="Confirm password" value="@ViewBag.ConfirmPassword" />
                <small id="passwordMatchStatus"></small>
            </div>

            <button class="btn">CREATE ACCOUNT</button>

        </form>
    </div>
</div>

<footer>
    @@ALL RIGHTS RESERVED · CODIE GO ADVENTURE · TEAM
</footer>

<script>
    const confirmInput = document.getElementById("confirm_password");
    const matchStatus = document.getElementById("passwordMatchStatus");

    const strengthContainer = document.getElementById("passwordStrengthContainer");
    const strengthFill = document.getElementById("strengthFill");
    const strengthText = document.getElementById("strengthText");

    const passwordInput = document.getElementById("password");
    const rules = document.getElementById("passwordRules");

    const ruleLength = document.getElementById("rule-length");
    const ruleUppercase = document.getElementById("rule-uppercase");
    const ruleNumberSymbol = document.getElementById("rule-number-symbol");

    passwordInput.addEventListener("focus", () => {

        rules.style.display = "block";
        strengthContainer.style.display = "block";

        updatePasswordUI();
    });

    passwordInput.addEventListener("blur", () => {

        if(passwordInput.value === ""){
            rules.style.display = "none";
            strengthContainer.style.display = "none";
        }

    });

    passwordInput.addEventListener("input", () => {
        updatePasswordUI();
        validateMatch();
    });


    confirmInput.addEventListener("input", validateMatch);

    function updatePasswordUI(){

        const value = passwordInput.value;

        ruleLength.style.color = value.length >= 8 ? "lightgreen" : "red";
        ruleUppercase.style.color = /[A-Z]/.test(value) ? "lightgreen" : "red";
        ruleNumberSymbol.style.color =
            (/\d/.test(value) || /[^A-Za-z0-9]/.test(value))
            ? "lightgreen"
            : "red";

        updateStrength(value);

    }

    function updateStrength(password){

        let score = 0;

        if(password.length >= 8) score++;
        if(/[A-Z]/.test(password)) score++;
        if(/\d/.test(password)) score++;
        if(/[^A-Za-z0-9]/.test(password)) score++;

        let percent = (score/4)*100;

        strengthFill.style.width = percent + "%";

        if(score <= 1){
            strengthFill.style.background = "red";
            strengthText.innerText = "Weak password";
            strengthText.style.color = "red";
        }
        else if(score == 2){
            strengthFill.style.background = "orange";
            strengthText.innerText = "Medium strength";
            strengthText.style.color = "orange";
        }
        else if(score >= 3){
            strengthFill.style.background = "lightgreen";
            strengthText.innerText = "Strong password";
            strengthText.style.color = "lightgreen";
        }

    }

    function validateMatch(){

        if(confirmInput.value.length === 0){
            matchStatus.innerText = "";
            return;
        }

        if(passwordInput.value === confirmInput.value){
            matchStatus.innerText = "✔ Passwords match";
            matchStatus.style.color = "lightgreen";
        }
        else{
            matchStatus.innerText = "✖ Passwords do not match";
            matchStatus.style.color = "red";
        }

    }

    const usernameInput = document.getElementById("username");
    const usernameStatus = document.getElementById("usernameStatus");

    let timeout = null;

    usernameInput.addEventListener("input", function () {

        clearTimeout(timeout);

        const username = usernameInput.value;

        if (username.length < 3) {
            usernameStatus.innerText = "";
            return;
        }

        timeout = setTimeout(() => {

            fetch(`/Account/CheckUsername?username=${username}`)
                .then(res => res.json())
                .then(data => {

                    if (data.available) {
                        usernameStatus.innerText = "✔ Username available";
                        usernameStatus.style.color = "lightgreen";
                    }
                    else {
                        usernameStatus.innerText = "✖ Username already taken";
                        usernameStatus.style.color = "red";
                    }

                });

        }, 500);

    });

    function togglePassword() {
        const input = document.getElementById("password");
        const input2 = document.getElementById("confirm_password");
        input.type = input.type === "password" ? "text" : "password";
        input2.type = input2.type === "password" ? "text" : "password";
    }
</script>
