@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CODIE GO ADVENTURE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodieGo_Adventure.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Grey+Qo&family=Pixelify+Sans:wght@400..700&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Orbitron', sans-serif;
        }

        body {
            height: 100vh;
            background: radial-gradient(circle at top, #0b1734, #040814 75%);
            color: #e5f6ff;
            overflow: hidden;
        }

            /* CYBER GRID */
            body::before {
                content: "";
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(0,255,255,.04) 2px, transparent 2px), linear-gradient(90deg, rgba(0,255,255,.04) 2px, transparent 2px);
                background-size: 60px 60px;
                pointer-events: none;
            }

        /* HEADER */
        .header {
            height: 70px;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid rgba(0,255,255,.25);
            background: linear-gradient(180deg,#0b1734,#060b1a);
            position: relative;
            z-index: 5;
        }

        .logo {
            color: #5df6ff;
            letter-spacing: 2px;
        }

        .nav {
            display: flex;
            gap: 25px;
        }

            .nav a {
                text-decoration: none;
                color: #9ffcff;
                opacity: .8;
            }

                .nav a.active {
                    color: #ff3cff;
                    border-bottom: 2px solid #ff3cff;
                }

        .right {
            display: flex;
            gap: 15px;
            font-size: 12px;
            align-items: center;
        }

        .page {
            position: relative;
            z-index: 2;
            height: calc(100vh - 70px);
            overflow-y: auto;
        }

        .quit-btn {
            padding: 10px 18px;
            background: linear-gradient(180deg,#ff4d6d,#c9184a);
            border: 2px solid #ff758f;
            color: white;
            font-weight: 600;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all .2s ease;
        }

            .quit-btn:hover {
                background: linear-gradient(180deg,#ff758f,#ff4d6d);
                box-shadow: 0 0 12px rgba(255,77,109,.7);
            }

            .quit-btn:active {
                transform: scale(.95);
            }
    </style>
</head>

<body>

    <header class="header">
        <div class="logo">&lt;/&gt; CODIE GO ADVENTURE</div>


        <nav class="nav">
            <button class="quit-btn @(currentController == "Experience" ? "active" : "")"
                    onclick="showConfirmPopup(
                    'QUIT GAME' ,
                    'Are you sure you want to quit?' ,
                    ()=>
                {
                window.location.href='@Url.Action(
                                    currentAction == "Module" ? "Modules" : "Challenges",
                                    "Home"
                                    )';
                })">
                I WISH TO GIVE UP
            </button>
        </nav>
    </header>

    <div id="content" class="page" style="scrollbar-width: none;">
        @RenderBody()
    </div>

    <script>
        function showRefreshLoader() {
            showGameLoader(
                'Refreshing...',
                'Reloading game resources'
            );
        }

        const content = document.getElementById("content");
        content.addEventListener("copy", e => e.preventDefault())
        content.addEventListener("paste", e => e.preventDefault())
        content.addEventListener('contextmenu', e => e.preventDefault());
        content.addEventListener('keydown', function(e) {
            if (e.key === "F12" || (e.ctrlKey && e.shiftKey && ["I","J"].includes(e.key.toUpperCase())) ||
            (e.ctrlKey && e.key.toUpperCase() === "U")) {
                e.preventDefault();
            }

            if (e.key === 'F5' ||
                (e.ctrlKey && e.key.toLowerCase() === 'r') ||
                (e.metaKey && e.key.toLowerCase() === 'r')) {
                const nav = performance.getEntriesByType("navigation")[0];

                if (nav && nav.type === "reload") {
                    showRefreshLoader();

                    setTimeout(() => {
                        hideGameLoader();
                    }, 1000);
                }
            }
        });
        window.addEventListener('load', function () {
            const nav = performance.getEntriesByType("navigation")[0];

            if (nav && nav.type === "reload") {
                showRefreshLoader();

                setTimeout(() => {
                    hideGameLoader();
                }, 1000);
            }
        });
    </script>

    @await Html.PartialAsync("_GamePopup")
    @await Html.PartialAsync("_LoaderPopup")
    @await Html.PartialAsync("_ToastPopup")
    @await Html.PartialAsync("_GameCompletion")
    @await Html.PartialAsync("_GameCompletionAssessment")
    @await Html.PartialAsync("_GameCompletionChallenge")
    @await Html.PartialAsync("_GameHUDMessage")
    @await Html.PartialAsync("_ConfirmationPopup")
    <script src="~/js/game-popup.js"></script>
    <script src="~/js/game-loader.js"></script>
    <script src="~/js/game-toast.js"></script>
    <script src="~/js/game-completion.js"></script>
    <script src="~/js/game-completion-assessment.js"></script>
    <script src="~/js/game-completion-challenge.js"></script>
    <script src="~/js/game-hud-message.js"></script>
    <script src="~/js/confirmation-popup.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
