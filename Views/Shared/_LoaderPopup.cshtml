<style>
    .game-loader-overlay {
        position: fixed;
        inset: 0;
        background: rgba(5, 10, 20, 0.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(4px);
        cursor: wait;
    }

    .game-loader {
        width: 380px;
        padding: 35px 30px;
        background: linear-gradient(180deg, #0b132b, #050a18);
        border: 2px solid #00f6ff;
        box-shadow: 0 0 25px rgba(0, 246, 255, 0.6), inset 0 0 15px rgba(0, 246, 255, 0.15);
        text-align: center;
    }

    .loader-spinner {
        width: 55px;
        height: 55px;
        margin: 0 auto 18px;
        border: 4px solid rgba(0, 246, 255, 0.2);
        border-top: 4px solid #00f6ff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .loader-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        color: #00f6ff;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .loader-message {
        font-size: 14px;
        color: #b8d9ff;
        opacity: 0.85;
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }
</style>

<div id="gameLoaderOverlay" class="game-loader-overlay">
    <div class="game-loader">
        <div class="loader-spinner"></div>
        <div class="loader-title">Authenticating...</div>
        <div class="loader-message">
            Please wait while we verify your credentials
        </div>
    </div>
</div>

